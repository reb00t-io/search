# use this file to initialize the virtual env
# usage: source venv.rc

venv=./.venv

mod_venv=venv
if ! command -v uv >/dev/null 2>&1; then
  echo "uv not found"
  return 1
fi

# create the venv if not yet there
if [ ! -d "$venv" ]; then

  # Prefer higher versions first
  for py in 3.13 3.12; do
    if uv python find "$py" >/dev/null 2>&1; then
      pyver="$py"
      break
    fi
  done

  if [ -z "$pyver" ]; then
    echo "Python >=3.12 not found via uv"
    return 1
  fi

  uv venv --python "$pyver" "$venv"
  source "$venv/bin/activate"
else
  source $venv/bin/activate
fi

# Install the project with dev extras (quote to avoid zsh globbing)
uv pip install --python .venv/bin/python -e '.[dev]'
